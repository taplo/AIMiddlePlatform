# ── AIMiddlePlatform Environment Variables ──
# Copy this file to .env and edit for your deployment.

## Application
APP_ENV=production
JWT_SECRET_KEY=change-me-in-production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-in-production

## Database (default: SQLite; switch to MySQL for production scale)
# DATABASE_URL=mysql+aiomysql://aimp:aimp_pass@mysql:3306/aimp
DATABASE_URL=sqlite+aiosqlite:///data/aimp.db

## Queue (Redis)
QUEUE_REDIS_URL=redis://redis:6379/0

## LLM API
LLM_API_URL=https://api.siliconflow.cn/v1
LLM_API_KEY=
LLM_MODEL_NAME=Qwen/Qwen2.5-VL-7B-Instruct

## S3 / MinIO Object Storage (optional, for saving analysis results)
S3_ENDPOINT=minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=aimp-results
S3_SECURE=false

## Data Collection (enable to save Agent I/O pairs for distillation)
# DATA_COLLECTION_ENABLED=true
DATA_COLLECTION_OUTPUT_DIR=data/collected/agent_pairs

## Prometheus metrics (worker only; default port 9090)
# WORKER_METRICS_PORT=9090
